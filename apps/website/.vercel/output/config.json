{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/account/profile/edit"
      },
      "src": "/dashboard/cuenta/perfil/editar"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/ads/pending"
      },
      "src": "/dashboard/anuncios/pendientes"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/ads/active"
      },
      "src": "/dashboard/anuncios/activos"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/ads/expired"
      },
      "src": "/dashboard/anuncios/expirados"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/ads/banned"
      },
      "src": "/dashboard/anuncios/baneados"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/ads/rejected"
      },
      "src": "/dashboard/anuncios/rechazados"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/ads/abandoned"
      },
      "src": "/dashboard/anuncios/abandonados"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/reservations/free"
      },
      "src": "/dashboard/reservas/libres"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/reservations/used"
      },
      "src": "/dashboard/reservas/usadas"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/featured/free"
      },
      "src": "/dashboard/destacados/libres"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/featured/used"
      },
      "src": "/dashboard/destacados/usados"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/users/[id]"
      },
      "src": "/dashboard/usuarios/[id]"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/account/profile"
      },
      "src": "/dashboard/cuenta/perfil"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/account/change-password"
      },
      "src": "/dashboard/cuenta/cambiar-contrasena"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/ads"
      },
      "src": "/dashboard/anuncios"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/orders"
      },
      "src": "/dashboard/ordenes"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/reservations"
      },
      "src": "/dashboard/reservas"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/featured"
      },
      "src": "/dashboard/destacados"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/users"
      },
      "src": "/dashboard/usuarios"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/account"
      },
      "src": "/dashboard/cuenta"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/categories"
      },
      "src": "/dashboard/categorias"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/conditions"
      },
      "src": "/dashboard/condiciones"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/regions"
      },
      "src": "/dashboard/regiones"
    },
    {
      "status": 301,
      "headers": {
        "Location": "/dashboard/communes"
      },
      "src": "/dashboard/comunas"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "X-Robots-Tag": "noindex"
      },
      "src": "/_nuxt"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable",
        "X-Robots-Tag": "noindex"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "headers": {
        "Referrer-Policy": "no-referrer",
        "Strict-Transport-Security": "max-age=15552000; includeSubDomains",
        "X-Content-Type-Options": "nosniff",
        "X-Download-Options": "noopen",
        "X-Frame-Options": "SAMEORIGIN",
        "X-Permitted-Cross-Domain-Policies": "none",
        "X-XSS-Protection": "0"
      },
      "src": "/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}
