{
  "kind": "collectionType",
  "collectionName": "verification_codes",
  "info": {
    "singularName": "verification-code",
    "pluralName": "verification-codes",
    "displayName": "VerificationCode",
    "description": "Stores pending 2-step login verification codes"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "userId": {
      "type": "integer",
      "required": true
    },
    "code": {
      "type": "string",
      "required": true
    },
    "expiresAt": {
      "type": "datetime",
      "required": true
    },
    "attempts": {
      "type": "integer",
      "default": 0
    },
    "pendingToken": {
      "type": "string",
      "unique": true,
      "required": true
    }
  }
}
