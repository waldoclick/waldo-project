# Server configuration
HOST=0.0.0.0
PORT=1337
APP_URL=http://localhost:1337
APP_KEYS=your_app_key_1,your_app_key_2,your_app_key_3,your_app_key_4
API_TOKEN_SALT=your_api_token_salt
ADMIN_JWT_SECRET=your_admin_jwt_secret
TRANSFER_TOKEN_SALT=your_transfer_token_salt

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Dashboard URL (used for password reset context routing)
DASHBOARD_URL=https://dashboard.waldo.click

# Database configuration
DATABASE_CLIENT=mysql
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=your_database_name
DATABASE_USERNAME=your_database_username
DATABASE_PASSWORD=your_database_password
DATABASE_SSL=false
JWT_SECRET=your_jwt_secret

# Mailgun configuration
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
MAILGUN_EMAIL=your_mailgun_email

# Webpay configuration
WEBPAY_COMMERCE_CODE=your_webpay_commerce_code
WEBPAY_API_KEY=your_webpay_api_key
WEBPAY_ENVIRONMENT=integration

# Oneclick configuration
ONECLICK_COMMERCE_CODE=your_oneclick_commerce_code
ONECLICK_API_KEY=your_oneclick_api_key
ONECLICK_ENVIRONMENT=integration
ONECLICK_CHILD_COMMERCE_CODE=597055555542

# Pro subscription pricing (in cents)
PRO_MONTHLY_PRICE=9990

# Google OAuth / One Tap configuration
GOOGLE_CLIENT_ID=your_google_client_id         # Used for OAuth sign-in AND One Tap token verification
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/login/google

# Google Spreadsheet configuration
GOOGLE_SPREADSHEET_ID=your_google_spreadsheet_id

# Zoho CRM configuration
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_API_URL=https://www.zohoapis.com

# Gemini AI configuration
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek AI configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic Claude AI configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Serper Search API configuration
SERPER_API_KEY=your_serper_api_key_here

# Tavily Search API configuration
TAVILY_API_KEY=your_tavily_api_key_here

# Google Search Console
GOOGLE_SC_CREDENTIALS_PATH=./google.json
GOOGLE_SC_SITE_URL=sc-domain:tudominio.cl
