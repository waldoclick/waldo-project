{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "./types"
    ],
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "../../node_modules/@vitejs/**/*",
    "../../node_modules/@vue/**/*",
    ".output",
    "dist"
  ],
  "strapi": {
    "version": "5"
  }
}
